# Default-deny the build context, then admit only image inputs.
*
!Dockerfile
!pyproject.toml
!uv.lock
!backend/
!backend/**
!docker/
!docker/**

# Never admit tests, runtime state, caches, media, or secrets from allowed trees.
backend/tests
backend/tests/**
backend/.contextbubble
backend/.contextbubble/**
backend/media
backend/media/**
backend/tmp
backend/tmp/**
backend/temp
backend/temp/**
**/__pycache__
**/*.py[cod]
**/*.sqlite*
**/*.db*
**/*.log
**/*.wav
**/*.mp3
**/*.m4a
**/*.aac
**/*.flac
**/*.ogg
**/*.mp4
**/*.mkv
**/*.webm
**/*.part
**/*.ytdl
.env
**/.env
**/.env*
**/.env.*
**/*.env
**/*.secret
**/*.secrets
**/*.token
**/*.key
**/*.pem

# Explicit exclusions retained as security documentation and contract anchors.
.git
