# Docker Compose override settings.
# Copy this file to .env only when Docker defaults need overrides, keep .env at
# 0600, and never commit real secrets. Native backend work should prefer
# .env.example.
#
# Leave blank to generate and persist the API token at /data/contextbubble.token.
CONTEXTBUBBLE_TOKEN=
ASR_PROVIDER=whisper_cpp

# whisper.cpp version used when building the image.
WHISPER_CPP_REF=v1.8.6

# Docker-only names avoid colliding with native .env host paths.
DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434

# The bundled default model is English-only.
DOCKER_WHISPER_MODEL=/models/ggml-base.en.bin
DOCKER_WHISPER_MODEL_URL=https://huggingface.co/ggerganov/whisper.cpp/resolve/80da2d8bfee42b0e836fc3a9890373e5defc00a6/ggml-base.en.bin
DOCKER_WHISPER_MODEL_SHA256=a03779c86df3323075f5e796cb2ce5029f00ec8869eee3fdfb897afe36c6d002
DOCKER_WHISPER_LANGUAGE=en

# For multilingual transcription, use the multilingual base model instead.
# DOCKER_WHISPER_MODEL=/models/ggml-base.bin
# DOCKER_WHISPER_MODEL_URL=https://huggingface.co/ggerganov/whisper.cpp/resolve/80da2d8bfee42b0e836fc3a9890373e5defc00a6/ggml-base.bin
# DOCKER_WHISPER_MODEL_SHA256=60ed5bc3dd14eea856493d334349b405782ddcaf0028d4b5df4088345fba2efe
# DOCKER_WHISPER_LANGUAGE=zh

# Analysis provider settings. Heuristic mode requires no external provider.
AGENT_MODE=heuristic
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_MODEL=qwen3:8b
TRANSLATION_MODE=ollama
TRANSLATION_MODEL=qwen3:8b
TRANSCRIPT_BLOCK_SPLITTER_MODE=ollama
TRANSCRIPT_BLOCK_SPLITTER_MODEL=llama3.2:3b

# Optional comma-separated YouTube video IDs used by demo flows.
DEMO_VIDEO_IDS=
